---
// 共通 chrome: head / fonts / footer (spec.md Repo structure)
// MDX page の layout frontmatter 経由でも、直接 import でも使えるよう両対応
import SiteHeader from '../components/SiteHeader.astro';
const props = Astro.props.frontmatter ?? Astro.props;
const { title, bare = false, description } = props;

const DEFAULT_DESC = '金融・感染・渋滞 ── 単純な個の相互作用から、暴落や渋滞がひとりでに立ち上がる。エージェント・ベース・モデルを、ブラウザの中で自分の手で動かす explorable。';
const desc = description ?? DEFAULT_DESC;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(import.meta.env.BASE_URL.replace(/\/$/, '') + '/og.png', Astro.site).href;
---

<!DOCTYPE html>
<html lang="ja">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={pageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ABM Explorables" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
        href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Spectral:wght@300;400;500&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
        rel="stylesheet" />
</head>

<body>
    <SiteHeader transparent={bare} />
    {bare ? <slot /> : (
    <div class="wrap">
        <slot />
        <footer class="site-foot">ABM Explorables</footer>
    </div>
    )}
</body>

</html>

<style is:global>
    /* design tokens + ページ骨格。:root / html / body は scoped だと当たらないため global に置く */
    :root {
        --bg: #0b0d12;
        --panel: #12151d;
        --panel2: #0f121a;
        --line: #222838;
        --text: #e8e9ee;
        --muted: #838aa0;
        --dim: #5b6276;
        --calm: #5a86d6;
        /* sub-critical */
        --warn: #e0a64e;
        /* near-critical */
        --crash: #ff5e57;
        /* super-critical */
        --gauss: #5a6172;
    }

    * {
        box-sizing: border-box
    }

    html,
    body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Spectral", Georgia, serif;
        -webkit-font-smoothing: antialiased
    }

    .wrap {
        max-width: 1060px;
        margin: 0 auto;
        /* 上余白は固定ヘッダー分を確保 */
        padding: 96px 28px 80px
    }

    /* スタブ/コンテンツページ共通 (about, why-abm 等) */
    .page-h {
        font-family: "Spectral", Georgia, serif;
        font-weight: 500;
        font-size: 30px;
        margin: 0 0 .4em
    }

    .page-p {
        font-size: 17px;
        line-height: 1.7;
        font-weight: 300;
        color: var(--muted);
        max-width: 60ch
    }

    .site-foot {
        margin-top: 60px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        font-size: 13px;
        color: var(--dim)
    }
</style>
