---
import Base from '../layouts/Base.astro';
import FireField from '../components/FireField.astro';

// base path 配下で 404 させない (spec 001/003 の地雷)。BASE_URL の末尾スラッシュは環境で揺れるため正規化。
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const demo = base + '/cases/cont-bouchaud/';
const epidemic = base + '/cases/epidemic/';
const traffic = base + '/cases/traffic/';
---

<Base title="ABM Explorables — 金融の複雑系を、自分の手で" description="一人ひとりは単純な規則で動くだけ。それなのに市場全体は誰の予想も超えていく ── その瞬間を、自分の手で再現できる explorable。" bare={true}>
    <section class="hero-scroll">
        <div class="hero-stage">
            <FireField />

            <div class="title-layer" id="titleLayer">
                <h1 class="big-title"><span class="w">ABM</span> <span class="w">Explorables</span></h1>
            </div>

            <div class="copy-layer" id="copyLayer">
                <p class="hero-msg">
                    <span>一人一人はごく単純な規則で動いているだけ</span>
                    <span>それなのに市場全体は誰の予想も超えていく</span>
                    <span class="last">その瞬間を、ぜひ自分の手で再現してみてほしい</span>
                </p>
            </div>

            <figcaption class="flame-cap">
                <span class="cap-a">森林火災モデル</span>
                <span class="cap-b">臨界に達した系では、たった一つの火花が野全体を駆け抜ける</span>
            </figcaption>

            <div class="scroll-hint" id="scrollHint" aria-hidden="true"><span class="hint-pulse">scroll ↓</span></div>
        </div>
    </section>

    <section class="below" id="sims">
        <h2 class="sims-h">Simulations</h2>
        <nav class="cases" aria-label="事例">
            <a class="case" href={demo}>
                <span class="case-t">群衆行動 — Herding</span>
                <span class="case-cite">Cont &amp; Bouchaud, 2000 · <i>Herd behavior and aggregate fluctuations in financial markets</i></span>
                <span class="case-d">連動する売り買いが群れをなすと、なぜ正規分布では説明できない暴落が生まれるのか</span>
            </a>
            <a class="case" href={epidemic}>
                <span class="case-t">感染の閾値 — Network SIR</span>
                <span class="case-cite">接触ネットワーク上の SIR · <i>Kermack &amp; McKendrick</i>, 1927</span>
                <span class="case-d">感染力をほんの少し上げるだけで、なぜ被害は比例ではなく、ある一点で跳ね上がるのか</span>
            </a>
            <a class="case" href={traffic}>
                <span class="case-t">幻の渋滞 — Phantom Jam</span>
                <span class="case-cite">Bando et al., 1995 · <i>Optimal Velocity Model</i>（杉山ら 2008 が実車で実証）</span>
                <span class="case-d">事故も合流もない一本道で、なぜ車を増やすだけで原因のない渋滞が生まれるのか</span>
            </a>
        </nav>
        <footer class="site-foot">ABM Explorables</footer>
    </section>
</Base>

<script>
    // hero スクロール進捗で 大タイトル→キャッチコピー をクロスフェード
    const wrap = document.querySelector('.hero-scroll');
    const title = document.getElementById('titleLayer');
    const copy = document.getElementById('copyLayer');
    const hint = document.getElementById('scrollHint');
    if (wrap && title && copy) {
        const clamp = (v, a, b) => Math.min(Math.max(v, a), b);
        let ticking = false;
        const apply = () => {
            const total = wrap.offsetHeight - window.innerHeight;
            const scrolled = clamp(-wrap.getBoundingClientRect().top, 0, total);
            const p = total > 0 ? scrolled / total : 0;
            const tOp = clamp(1 - p / 0.40, 0, 1);   // タイトルは前半で消える
            const cOp = clamp((p - 0.30) / 0.40, 0, 1); // コピーは中盤で浮かぶ
            title.style.opacity = tOp;
            if (hint) hint.style.opacity = tOp;
            copy.style.opacity = cOp;
            copy.style.transform = `translateY(${((1 - cOp) * 18).toFixed(1)}px)`;
            ticking = false;
        };
        window.addEventListener('scroll', () => {
            if (!ticking) { requestAnimationFrame(apply); ticking = true; }
        }, { passive: true });
        window.addEventListener('resize', apply);
        apply();
    }
</script>

<style>
    /* sticky scrollytelling: 大タイトル → スクロールでキャッチコピーへクロスフェード */
    .hero-scroll {
        position: relative;
        height: 200svh
    }

    .hero-stage {
        position: sticky;
        top: 0;
        height: 100svh;
        overflow: hidden
    }

    .title-layer,
    .copy-layer {
        position: absolute;
        inset: 0;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 0 24px;
        text-align: center;
        will-change: opacity, transform
    }

    .copy-layer {
        opacity: 0;
        transform: translateY(18px)
    }

    .big-title {
        margin: 0;
        /* Simudyne 的な素っ気ない sans。凝った webfont より plain な system フォントで */
        font-family: "Helvetica Neue", Arial, "Segoe UI", system-ui, sans-serif;
        font-weight: 400;
        font-size: clamp(46px, 11.5vw, 150px);
        line-height: 1.0;
        letter-spacing: -.025em;
        color: var(--text);
        text-shadow: 0 2px 40px var(--bg), 0 1px 8px var(--bg)
    }

    .big-title .w {
        display: inline
    }

    .hero-msg {
        margin: 0;
        max-width: 1060px;
        font-family: "Spectral", Georgia, serif;
        font-weight: 400;
        font-size: clamp(21px, 3.1vw, 37px);
        line-height: 1.95;
        letter-spacing: .01em;
        color: var(--text);
        /* 炎が稀に文字を横切っても読めるよう、グラデ装飾ではなく文字影で legibility を担保 */
        text-shadow: 0 1px 24px var(--bg), 0 1px 5px var(--bg)
    }

    .hero-msg span {
        display: block
    }

    .hero-msg .last {
        margin-top: .8em;
        color: #c8cbd6;
        font-weight: 300
    }

    /* 縦長(スマホ)では ABM / Explorables を2段に */
    @media (max-width: 600px) {
        .big-title {
            font-size: clamp(40px, 13vw, 92px);
            line-height: 1.04
        }

        .big-title .w {
            display: block
        }
    }

    .scroll-hint {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 64px;
        z-index: 1;
        text-align: center;
        font-family: "IBM Plex Mono", monospace;
        font-size: 11px;
        letter-spacing: .22em;
        color: var(--dim);
        text-shadow: 0 1px 14px var(--bg);
        pointer-events: none
    }

    .hint-pulse {
        animation: hintPulse 2.4s ease-in-out infinite
    }

    @keyframes hintPulse {
        0%, 100% { opacity: .4 }
        50% { opacity: .9 }
    }

    /* 延焼の作品ラベル — hero 左下隅にひっそり置く(中央のコピーと競合させない) */
    .flame-cap {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 26px;
        z-index: 1;
        max-width: 1060px;
        margin: 0 auto;
        padding: 0 28px;
        font-size: 12.5px;
        line-height: 1.65;
        color: var(--muted);
        text-shadow: 0 1px 14px var(--bg), 0 1px 4px var(--bg);
        pointer-events: none
    }

    .flame-cap .cap-a,
    .flame-cap .cap-b {
        display: block
    }

    .flame-cap .cap-a {
        color: var(--text);
        letter-spacing: .02em
    }

    .flame-cap .cap-b {
        color: #c8cbd6
    }

    /* 下段 — Simulations */
    .below {
        max-width: 1060px;
        margin: 0 auto;
        padding: 70px 28px 80px;
        scroll-margin-top: 72px
    }

    .sims-h {
        margin: 0 0 8px;
        font-family: "Spectral", Georgia, serif;
        font-size: 15px;
        font-weight: 500;
        color: var(--muted)
    }

    .cases {
        display: flex;
        flex-direction: column;
        gap: 0
    }

    .case {
        display: block;
        padding: 22px 0;
        border-top: 1px solid var(--line);
        text-decoration: none;
        color: inherit;
        transition: padding-left .2s
    }

    .case:last-of-type {
        border-bottom: 1px solid var(--line)
    }

    .case:hover {
        padding-left: 8px
    }

    .case-t {
        display: block;
        font-family: "Spectral", Georgia, serif;
        font-size: 21px;
        font-weight: 500;
        color: var(--text);
        margin-bottom: 4px
    }

    .case:hover .case-t {
        color: var(--calm)
    }

    .case-cite {
        display: block;
        font-size: 12.5px;
        line-height: 1.5;
        color: var(--dim);
        margin-bottom: 8px
    }

    .case-cite i {
        font-style: italic
    }

    .case-d {
        display: block;
        font-size: 15px;
        line-height: 1.55;
        font-weight: 300;
        color: var(--muted)
    }

    .site-foot {
        margin-top: 56px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        font-size: 13px;
        color: var(--dim)
    }
</style>
