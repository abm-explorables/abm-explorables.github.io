---
import Base from '../layouts/Base.astro';
import FireField from '../components/FireField.astro';

// base path 配下で 404 させない (spec 001/003 の地雷)。BASE_URL の末尾スラッシュは環境で揺れるため正規化。
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const demo = base + '/cases/cont-bouchaud/';
const epidemic = base + '/cases/epidemic/';
const traffic = base + '/cases/traffic/';
---

<Base title="ABM Explorables — 金融の複雑系を、自分の手で" description="一人ひとりは単純な規則で動くだけ。それなのに市場全体は誰の予想も超えていく ── その瞬間を、自分の手で再現できる explorable。" bare={true}>
    <section class="hero">
        <FireField />
        <div class="hero-inner">
            <h1 class="hero-msg">
                <span>一人一人はごく単純な規則で動いているだけ</span>
                <span>それなのに市場全体は誰の予想も超えていく</span>
                <span class="last">その瞬間を、ぜひ自分の手で再現してみてほしい</span>
            </h1>
        </div>

        <figcaption class="flame-cap">
            <span class="cap-a">森林火災モデル</span>
            <span class="cap-b">臨界に達した系では、たった一つの火花が野全体を駆け抜ける</span>
        </figcaption>
    </section>

    <section class="below" id="sims">
        <h2 class="sims-h">Simulations</h2>
        <nav class="cases" aria-label="事例">
            <a class="case" href={demo}>
                <span class="case-t">群衆行動 — Herding</span>
                <span class="case-cite">Cont &amp; Bouchaud, 2000 · <i>Herd behavior and aggregate fluctuations in financial markets</i></span>
                <span class="case-d">連動する売り買いが群れをなすと、なぜ正規分布では説明できない暴落が生まれるのか</span>
            </a>
            <a class="case" href={epidemic}>
                <span class="case-t">感染の閾値 — Network SIR</span>
                <span class="case-cite">接触ネットワーク上の SIR · <i>Kermack &amp; McKendrick</i>, 1927</span>
                <span class="case-d">感染力をほんの少し上げるだけで、なぜ被害は比例ではなく、ある一点で跳ね上がるのか</span>
            </a>
            <a class="case" href={traffic}>
                <span class="case-t">幻の渋滞 — Phantom Jam</span>
                <span class="case-cite">Bando et al., 1995 · <i>Optimal Velocity Model</i>（杉山ら 2008 が実車で実証）</span>
                <span class="case-d">事故も合流もない一本道で、なぜ車を増やすだけで原因のない渋滞が生まれるのか</span>
            </a>
        </nav>
        <footer class="site-foot">ABM Explorables</footer>
    </section>
</Base>

<style>
    .hero {
        position: relative;
        min-height: 100svh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center
    }

    /* 中央のキャッチコピー + 軽い説明 */
    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 1060px;
        width: 100%;
        margin: 0 auto;
        padding: 0 28px;
        text-align: center
    }

    .hero-msg {
        margin: 0;
        font-family: "Spectral", Georgia, serif;
        font-weight: 400;
        font-size: clamp(21px, 3.1vw, 37px);
        line-height: 1.95;
        letter-spacing: .01em;
        color: var(--text);
        /* 炎が稀に文字を横切っても読めるよう、グラデ装飾ではなく文字影で legibility を担保 */
        text-shadow: 0 1px 24px var(--bg), 0 1px 5px var(--bg)
    }

    .hero-msg span {
        display: block
    }

    .hero-msg .last {
        margin-top: .8em;
        color: #c8cbd6;
        font-weight: 300
    }

    /* 延焼の作品ラベル — hero 左下隅にひっそり置く(中央のコピーと競合させない) */
    .flame-cap {
        position: absolute;
        left: 0;
        right: 0;
        bottom: 26px;
        z-index: 1;
        max-width: 1060px;
        margin: 0 auto;
        padding: 0 28px;
        font-size: 12.5px;
        line-height: 1.65;
        color: var(--muted);
        text-shadow: 0 1px 14px var(--bg), 0 1px 4px var(--bg);
        pointer-events: none
    }

    .flame-cap .cap-a,
    .flame-cap .cap-b {
        display: block
    }

    .flame-cap .cap-a {
        color: var(--text);
        letter-spacing: .02em
    }

    .flame-cap .cap-b {
        color: #c8cbd6
    }

    /* 下段 — Simulations */
    .below {
        max-width: 1060px;
        margin: 0 auto;
        padding: 70px 28px 80px;
        scroll-margin-top: 72px
    }

    .sims-h {
        margin: 0 0 8px;
        font-family: "Spectral", Georgia, serif;
        font-size: 15px;
        font-weight: 500;
        color: var(--muted)
    }

    .cases {
        display: flex;
        flex-direction: column;
        gap: 0
    }

    .case {
        display: block;
        padding: 22px 0;
        border-top: 1px solid var(--line);
        text-decoration: none;
        color: inherit;
        transition: padding-left .2s
    }

    .case:last-of-type {
        border-bottom: 1px solid var(--line)
    }

    .case:hover {
        padding-left: 8px
    }

    .case-t {
        display: block;
        font-family: "Spectral", Georgia, serif;
        font-size: 21px;
        font-weight: 500;
        color: var(--text);
        margin-bottom: 4px
    }

    .case:hover .case-t {
        color: var(--calm)
    }

    .case-cite {
        display: block;
        font-size: 12.5px;
        line-height: 1.5;
        color: var(--dim);
        margin-bottom: 8px
    }

    .case-cite i {
        font-style: italic
    }

    .case-d {
        display: block;
        font-size: 15px;
        line-height: 1.55;
        font-weight: 300;
        color: var(--muted)
    }

    .site-foot {
        margin-top: 56px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        font-size: 13px;
        color: var(--dim)
    }
</style>
