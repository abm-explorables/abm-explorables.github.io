---
import Base from '../layouts/Base.astro';
import FireField from '../components/FireField.astro';

// base path 配下で 404 させない (spec 001/003 の地雷)。BASE_URL の末尾スラッシュは環境で揺れるため正規化。
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const home = base + '/';
const about = base + '/about/';
const demo = base + '/cases/cont-bouchaud/';
---

<Base title="ABM Explorables — 金融の複雑系を、自分の手で" bare={true}>
    <section class="hero">
        <FireField />

        <header class="site-head">
            <a class="brand" href={home}>ABM Explorables</a>
            <nav class="nav" aria-label="メイン">
                <a href="#sims">Simulations</a>
                <a class="soon-link" href={about}>About <span class="soon">準備中</span></a>
            </nav>
        </header>

        <div class="hero-inner">
            <h1 class="hero-msg">
                <span>一人一人はごく単純な規則で動いているだけ</span>
                <span>それなのに市場全体は誰の予想も超えていく</span>
                <span class="last">その瞬間を、ぜひ自分の手で再現してみてほしい</span>
            </h1>
            <p class="hero-sub">背景は森林火災モデル。臨界に達した系では、たった一つの火花が野全体を駆け抜ける ── 群れの暴走もこれと同じ構造から生まれる。</p>
        </div>
    </section>

    <section class="below" id="sims">
        <h2 class="sims-h">Simulations</h2>
        <nav class="cases" aria-label="事例">
            <a class="case" href={demo}>
                <span class="case-t">臨界点 — Cont-Bouchaud</span>
                <span class="case-d">連動する群れが増えると、なぜ正規分布では説明できない暴落が生まれるのか</span>
            </a>
        </nav>
        <footer class="site-foot">ABM Explorables</footer>
    </section>
</Base>

<style>
    .hero {
        position: relative;
        min-height: 100svh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center
    }

    /* header — 延焼の上に重ねる */
    .site-head {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        z-index: 2;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        max-width: 1060px;
        margin: 0 auto;
        padding: 22px 28px;
        flex-wrap: wrap
    }

    .brand {
        font-family: "Spectral", Georgia, serif;
        font-size: 16px;
        font-weight: 500;
        color: var(--text);
        text-decoration: none;
        letter-spacing: .01em;
        text-shadow: 0 1px 16px var(--bg)
    }

    .nav {
        display: flex;
        gap: 24px;
        align-items: baseline
    }

    .nav a {
        font-family: "Spectral", Georgia, serif;
        font-size: 15px;
        color: var(--muted);
        text-decoration: none;
        transition: color .2s;
        text-shadow: 0 1px 16px var(--bg)
    }

    .nav a:hover {
        color: var(--calm)
    }

    .soon {
        font-size: 11px;
        color: var(--dim)
    }

    /* 中央のキャッチコピー + 軽い説明 */
    .hero-inner {
        position: relative;
        z-index: 1;
        max-width: 1060px;
        width: 100%;
        margin: 0 auto;
        padding: 0 28px;
        text-align: center
    }

    .hero-msg {
        margin: 0;
        font-family: "Spectral", Georgia, serif;
        font-weight: 400;
        font-size: clamp(21px, 3.1vw, 37px);
        line-height: 1.95;
        letter-spacing: .01em;
        color: var(--text);
        /* 炎が稀に文字を横切っても読めるよう、グラデ装飾ではなく文字影で legibility を担保 */
        text-shadow: 0 1px 24px var(--bg), 0 1px 5px var(--bg)
    }

    .hero-msg span {
        display: block
    }

    .hero-msg .last {
        margin-top: .8em;
        color: #c8cbd6;
        font-weight: 300
    }

    .hero-sub {
        margin: 34px auto 0;
        max-width: 54ch;
        font-size: 15px;
        line-height: 1.8;
        font-weight: 300;
        color: var(--muted);
        text-shadow: 0 1px 16px var(--bg)
    }

    /* 下段 — Simulations */
    .below {
        max-width: 1060px;
        margin: 0 auto;
        padding: 70px 28px 80px;
        scroll-margin-top: 20px
    }

    .sims-h {
        margin: 0 0 8px;
        font-family: "Spectral", Georgia, serif;
        font-size: 15px;
        font-weight: 500;
        color: var(--muted)
    }

    .cases {
        display: flex;
        flex-direction: column;
        gap: 0
    }

    .case {
        display: block;
        padding: 22px 0;
        border-top: 1px solid var(--line);
        text-decoration: none;
        color: inherit;
        transition: padding-left .2s
    }

    .case:last-of-type {
        border-bottom: 1px solid var(--line)
    }

    .case:hover {
        padding-left: 8px
    }

    .case-t {
        display: block;
        font-family: "Spectral", Georgia, serif;
        font-size: 21px;
        font-weight: 500;
        color: var(--text);
        margin-bottom: 5px
    }

    .case:hover .case-t {
        color: var(--calm)
    }

    .case-d {
        display: block;
        font-size: 15px;
        line-height: 1.55;
        font-weight: 300;
        color: var(--muted);
        max-width: 64ch
    }

    .site-foot {
        margin-top: 56px;
        padding-top: 18px;
        border-top: 1px solid var(--line);
        font-size: 13px;
        color: var(--dim)
    }
</style>
