</style>

<script>
    (() => {
        const N = 700, R = 0.055, GAMMA = 0.035, MAXT = 520;
        const TC = 0.241;
        // ---- layout: random points in unit square ----
        const px = new Float32Array(N), py = new Float32Array(N);
        for (let i = 0; i < N; i++) { px[i] = 0.04 + 0.92 * Math.random(); py[i] = 0.04 + 0.92 * Math.random(); }
        // ---- spatial neighbour lists + edges ----
        const nb = Array.from({ length: N }, () => []); const edges = [];
        const R2 = R * R;
        for (let i = 0; i < N; i++)for (let j = i + 1; j < N; j++) {
            const dx = px[i] - px[j], dy = py[i] - py[j];
            if (dx * dx + dy * dy < R2) { nb[i].push(j); nb[j].push(i); edges.push(i, j); }
        }
        let degSum = 0; for (let i = 0; i < N; i++) degSum += nb[i].length;
        const meanDeg = degSum / N;
        // place threshold mark: beta at which edge transmissibility T = TC, slider max 0.05
        const betaCrit = TC * GAMMA / (1 - TC); document.querySelector('.mark').style.left = (betaCrit / 0.05 * 100).toFixed(1) + '%';

        let beta = 0.010, dist = 0, vacc = 0, running = true;
        const state = new Int8Array(N);   // 0 S, 1 I, 2 R
        let everInf = 0, peak = 0;
        const curve = [], sir = [];
        const mark = new Uint8Array(N);

        function reset() {
            state.fill(0); everInf = 0; peak = 0; curve.length = 0; sir.length = 0;
            // vaccinate
            const nv = Math.floor(vacc * N); const idx = [...Array(N).keys()];
            for (let k = 0; k < nv; k++) { const r = k + ((Math.random() * (N - k)) | 0);[idx[k], idx[r]] = [idx[r], idx[k]]; state[idx[k]] = 2; }
            // seed
            let seeded = 0; let guard = 0;
            while (seeded < 4 && guard++ < 2000) { const i = (Math.random() * N) | 0; if (state[i] === 0) { state[i] = 1; everInf++; seeded++; } }
        }
        reset();

        function step() {
            const pre = []; for (let i = 0; i < N; i++) if (state[i] === 1) pre.push(i);
            mark.fill(0);
            const eb = beta * (1 - dist);
            for (const i of pre) { for (const j of nb[i]) { if (state[j] === 0 && Math.random() < eb) mark[j] = 1; } }
            for (const i of pre) { if (Math.random() < GAMMA) state[i] = 2; }
            for (let j = 0; j < N; j++) { if (mark[j]) { state[j] = 1; everInf++; } }
            let s = 0, inf = 0, r = 0; for (let i = 0; i < N; i++) { const v = state[i]; if (v === 0) s++; else if (v === 1) inf++; else r++; }
            if (inf > peak) peak = inf;
            curve.push(inf); if (curve.length > MAXT) curve.shift();
            sir.push([s, inf, r]); if (sir.length > MAXT) sir.shift();
        }

        function fit(cv, h) {
            const dpr = devicePixelRatio || 1; const w = cv.clientWidth;
            cv.width = w * dpr; cv.height = h * dpr; cv.style.height = h + 'px';
            const g = cv.getContext('2d'); g.setTransform(dpr, 0, 0, dpr, 0, 0); return [g, w, h];
        }
        const netCv = document.getElementById('cNet'), curCv = document.getElementById('cCurve'), sirCv = document.getElementById('cSir');
        const COL = ['#46527a', '#ff5e57', '#5fae9e'];

        function drawNet() {
            const [g, w, h] = fit(netCv, 440);
            g.clearRect(0, 0, w, h);
            const m = 20, sx = w - 2 * m, sy = h - 2 * m;
            g.lineWidth = 0.5; g.strokeStyle = 'rgba(120,134,170,0.10)';
            for (let k = 0; k < edges.length; k += 2) {
                const i = edges[k], j = edges[k + 1];
                g.beginPath(); g.moveTo(m + px[i] * sx, m + py[i] * sy); g.lineTo(m + px[j] * sx, m + py[j] * sy); g.stroke();
            }
            for (let i = 0; i < N; i++) {
                const st = state[i];
                g.fillStyle = COL[st]; const rad = st === 1 ? 3.0 : 2.1;
                g.beginPath(); g.arc(m + px[i] * sx, m + py[i] * sy, rad, 0, 7); g.fill();
            }
        }
        function drawCurve() {
            const [g, w, h] = fit(curCv, 150);
            g.clearRect(0, 0, w, h);
            if (curve.length < 2) return;
            const yMax = Math.max(peak, 8) * 1.1;
            const X = i => i / (MAXT - 1) * (w - 6) + 3, Y = v => h - 8 - v / yMax * (h - 16);
            g.beginPath(); curve.forEach((v, i) => { i ? g.lineTo(X(i), Y(v)) : g.moveTo(X(i), Y(v)); });
            g.lineTo(X(curve.length - 1), h); g.lineTo(X(0), h); g.closePath();
            g.fillStyle = 'rgba(255,94,87,0.16)'; g.fill();
            g.beginPath(); curve.forEach((v, i) => { i ? g.lineTo(X(i), Y(v)) : g.moveTo(X(i), Y(v)); });
            g.strokeStyle = '#ff5e57'; g.lineWidth = 1.5; g.stroke();
        }
        function drawSir() {
            const [g, w, h] = fit(sirCv, 150);
            g.clearRect(0, 0, w, h);
            if (sir.length < 2) return;
            const X = i => i / (MAXT - 1) * (w - 6) + 3;
            // stacked: S bottom, I middle, R top (fractions of N)
            const layer = (pick, col) => {
                g.beginPath();
                for (let i = 0; i < sir.length; i++) { const y = h - (sir[i][0] + (pick >= 1 ? sir[i][1] : 0) + (pick >= 2 ? sir[i][2] : 0)) / N * h; i ? g.lineTo(X(i), y) : g.moveTo(X(i), y); }
                // close along baseline of previous layer
                for (let i = sir.length - 1; i >= 0; i--) { const y = pick === 0 ? h : h - (sir[i][0] + (pick >= 2 ? sir[i][1] : 0)) / N * h; g.lineTo(X(i), y); }
                g.closePath(); g.fillStyle = col; g.fill();
            };
            // draw R (full) then I then S so stacking reads; simpler: paint cumulative bands
            // band S
            g.beginPath(); for (let i = 0; i < sir.length; i++) { const y = h - sir[i][0] / N * h; i ? g.lineTo(X(i), y) : g.moveTo(X(i), y); } g.lineTo(X(sir.length - 1), h); g.lineTo(X(0), h); g.closePath(); g.fillStyle = 'rgba(70,82,122,0.55)'; g.fill();
            // band S+I
            g.beginPath(); for (let i = 0; i < sir.length; i++) { const y = h - (sir[i][0] + sir[i][1]) / N * h; i ? g.lineTo(X(i), y) : g.moveTo(X(i), y); } for (let i = sir.length - 1; i >= 0; i--) { const y = h - sir[i][0] / N * h; g.lineTo(X(i), y); } g.closePath(); g.fillStyle = 'rgba(255,94,87,0.7)'; g.fill();
            // band S+I+R (rest)
            g.beginPath(); for (let i = 0; i < sir.length; i++) { const y = h - (sir[i][0] + sir[i][1] + sir[i][2]) / N * h; i ? g.lineTo(X(i), y) : g.moveTo(X(i), y); } for (let i = sir.length - 1; i >= 0; i--) { const y = h - (sir[i][0] + sir[i][1]) / N * h; g.lineTo(X(i), y); } g.closePath(); g.fillStyle = 'rgba(95,174,158,0.55)'; g.fill();
        }

        const badge = document.getElementById('badge'), story = document.getElementById('story');
        const rR0 = document.getElementById('rR0'), rA = document.getElementById('rActive'), rT = document.getElementById('rTotal'), rP = document.getElementById('rPeak');
        const lblB = document.getElementById('lblB'), lblD = document.getElementById('lblD'), lblV = document.getElementById('lblV');
        const stories = {
            sub: 'R₀ が 1 を下回り、感染は数人で打ち消えて消える。隣に伝わる前に回復してしまうため、流行は立ち上がらない。',
            edge: 'R₀ が 1 の縁。火種が消えるか燃え広がるかは紙一重で、結果が試行ごとに大きくぶれる ── 臨界のゆらぎだ。',
            sup: 'R₀ が 1 を大きく超え、感染が集団全体へ燃え広がる。距離確保で接触を削るか、ワクチンで燃料を間引けば、同じ感染力でも流行は止められる。'
        };
        let lastCls = '';
        function paint() {
            let s = 0, inf = 0, r = 0; for (let i = 0; i < N; i++) { const v = state[i]; if (v === 0) s++; else if (v === 1) inf++; else r++; }
            const eb = beta * (1 - dist); const T = eb / (eb + GAMMA); const R0 = T / TC * (1 - vacc);
            const cls = R0 < 0.95 ? 'sub' : (R0 < 1.4 ? 'edge' : 'sup');
            const col = cls === 'sub' ? '#5fae9e' : (cls === 'edge' ? '#e0a64e' : '#ff5e57');
            const txt = cls === 'sub' ? '収束 / sub-threshold' : (cls === 'edge' ? '臨界近傍 / near-threshold' : '大流行 / supercritical');
            badge.textContent = '— ' + txt; badge.style.color = col;
            rR0.textContent = R0.toFixed(2);
            rA.textContent = (inf / N * 100).toFixed(1) + '%';
            rT.textContent = (everInf / N * 100).toFixed(0) + '%';
            rP.textContent = (peak / N * 100).toFixed(0) + '%';
            lblB.style.color = col;
            if (cls !== lastCls) { lastCls = cls; story.innerHTML = '<b>いま見えていること:</b> ' + stories[cls]; const b = story.querySelector('b'); if (b) b.style.color = col; }
        }

        let acc = 0, last = performance.now();
        function loop(now) {
            const dt = now - last; last = now;
            if (running) { acc += dt; while (acc >= 70) { step(); acc -= 70; } }
            drawNet(); drawCurve(); drawSir(); paint();
            requestAnimationFrame(loop);
        }
        const sB = document.getElementById('sB'), sD = document.getElementById('sD'), sV = document.getElementById('sV');
        sB.addEventListener('input', e => { beta = +e.target.value; lblB.textContent = beta.toFixed(3); });
        sD.addEventListener('input', e => { dist = +e.target.value; lblD.textContent = Math.round(dist * 100) + '%'; });
        sV.addEventListener('input', e => { vacc = +e.target.value; lblV.textContent = Math.round(vacc * 100) + '%'; });
        document.getElementById('bPlay').addEventListener('click', e => { running = !running; e.target.textContent = running ? '⏸ pause' : '▶ play'; last = performance.now(); });
        document.getElementById('bReset').addEventListener('click', reset);

        for (let i = 0; i < 40; i++) step();
        requestAnimationFrame(loop);
    })();
</script>
