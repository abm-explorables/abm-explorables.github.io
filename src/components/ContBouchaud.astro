</style>

<script>
    (() => {
        const N = 360, MAXR = 600, LIQ = 1000;
        // ---- agent layout: phyllotaxis disk ----
        const px = new Float32Array(N), py = new Float32Array(N);
        const GA = Math.PI * (3 - Math.sqrt(5));
        for (let i = 0; i < N; i++) { const r = Math.sqrt(i / N), t = i * GA; px[i] = r * Math.cos(t); py[i] = r * Math.sin(t); }

        // ---- union-find ----
        const parent = new Int32Array(N), size = new Int32Array(N);
        function find(x) { while (parent[x] !== x) { parent[x] = parent[parent[x]]; x = parent[x]; } return x; }
        function uni(a, b) { a = find(a); b = find(b); if (a === b) return; if (size[a] < size[b]) { const t = a; a = b; b = t; } parent[b] = a; size[a] += size[b]; }

        let c = 0.30, a = 0.15, running = true;
        const root = new Int32Array(N);
        let edges = [], giantRoot = -1, giantSize = 0;
        const act = new Map();            // root -> action this tick (+1/-1/0)
        let price = 100; const rets = [], prices = []; let flashA = 0;

        function step() {
            for (let i = 0; i < N; i++) { parent[i] = i; size[i] = 1; }
            const m = Math.round(c * N / 2); edges.length = 0;
            for (let k = 0; k < m; k++) {
                const i = (Math.random() * N) | 0; let j = (Math.random() * N) | 0;
                if (i === j) continue; uni(i, j); edges.push(i, j);
            }
            giantSize = 0; giantRoot = -1;
            for (let i = 0; i < N; i++) { const r = find(i); root[i] = r; if (i === r && size[i] > giantSize) { giantSize = size[i]; giantRoot = r; } }
            // each cluster acts once
            act.clear(); let demand = 0; let giantHit = 0;
            for (let i = 0; i < N; i++) {
                if (parent[i] === i) {
                    const u = Math.random(); let phi = 0;
                    if (u < a) phi = 1; else if (u < 2 * a) phi = -1;
                    act.set(i, phi);
                    demand += size[i] * phi;
                    if (i === giantRoot) giantHit = Math.abs(phi) * size[i];
                }
            }
            const lr = demand / LIQ;
            price *= Math.exp(lr);
            rets.push(lr); if (rets.length > MAXR) rets.shift();
            prices.push(price); if (prices.length > 400) prices.shift();
            if (Math.abs(lr) > 0.04) flashA = Math.min(1, Math.abs(lr) * 6);
        }

        // ---- stats ----
        function stats() {
            const n = rets.length; if (n < 8) return { sd: 0, kurt: 0, mx: 0, gf: giantSize / N };
            let m = 0; for (const x of rets) m += x; m /= n;
            let v = 0, q = 0, mx = 0; for (const x of rets) { const d = x - m; v += d * d; }
            v /= n; const sd = Math.sqrt(v);
            for (const x of rets) { const d = x - m; q += d * d * d * d; const am = Math.abs(x); if (am > mx) mx = am; }
            const kurt = sd > 0 ? q / (n * v * v) - 3 : 0;
            return { sd, kurt, mx, gf: giantSize / N };
        }

        // ---- canvas helpers ----
        function fit(cv, h) {
            const dpr = devicePixelRatio || 1; const w = cv.clientWidth;
            cv.width = w * dpr; cv.height = h * dpr; cv.style.height = h + 'px';
            const g = cv.getContext('2d'); g.setTransform(dpr, 0, 0, dpr, 0, 0); return [g, w, h];
        }
        const netCv = document.getElementById('cNet');
        const priCv = document.getElementById('cPrice');
        const disCv = document.getElementById('cDist');
        const flash = document.getElementById('flash');

        function hue(r) { return (r * 47) % 360; }
        const REGIMES = {
            sub: { cls: 'sub', col: '#5a86d6', txt: '安定 / sub-critical' },
            near: { cls: 'near', col: '#e0a64e', txt: '臨界近傍 / near-critical' },
            sup: { cls: 'sup', col: '#ff5e57', txt: '群衆支配 / super-critical' }
        };
        function regime(gf) {
            if (gf < 0.08) return REGIMES.sub;
            if (gf < 0.20) return REGIMES.near;
            return REGIMES.sup;
        }
        const stories = {
            sub: 'クラスタは小さく分断され、無数の独立な売り買いが打ち消し合う。リターンはほぼ正規分布。暴落は起きない。',
            near: '巨大クラスタが生まれ始めた。分布の裾が太り出し、たまに大きな一撃が混じる ── 平穏に見えて、市場は崖の縁に近づいている。',
            sup: '市場が一つの群れに支配されている。普段は静かでも、その群れが一斉に動いた瞬間に価格が吹き飛ぶ。これがテールリスクの爆発 ── 正規分布が決して許さない暴落が、構造から生まれる。'
        };

        function drawNet() {
            const [g, w, h] = fit(netCv, 420);
            g.clearRect(0, 0, w, h);
            const cx = w / 2, cy = h / 2, R = Math.min(w, h) / 2 - 22;
            // edges
            g.lineWidth = 0.6;
            for (let k = 0; k < edges.length; k += 2) {
                const i = edges[k], j = edges[k + 1];
                const big = (root[i] === giantRoot && giantSize > 0.08 * N);
                g.strokeStyle = big ? 'rgba(255,94,87,0.30)' : 'rgba(120,130,160,0.14)';
                g.beginPath();
                g.moveTo(cx + px[i] * R, cy + py[i] * R);
                g.lineTo(cx + px[j] * R, cy + py[j] * R);
                g.stroke();
            }
            // nodes
            for (let i = 0; i < N; i++) {
                const r = root[i], big = (r === giantRoot && giantSize > 0.08 * N);
                const traded = act.get(r) !== 0 && act.get(r) !== undefined;
                let col;
                if (big) { col = traded ? '#ff7a73' : '#ff5e57'; }
                else { col = `hsl(${hue(r)},22%,${size[r] > 1 ? 52 : 34}%)`; }
                const rad = big ? 3.1 : (size[r] > 1 ? 2.4 : 1.7);
                g.fillStyle = col;
                g.beginPath();
                g.arc(cx + px[i] * R, cy + py[i] * R, rad, 0, 7);
                g.fill();
            }
        }

        function drawPrice() {
            const [g, w, h] = fit(priCv, 150);
            g.clearRect(0, 0, w, h);
            if (prices.length < 2) return;
            let lo = Infinity, hi = -Infinity; for (const p of prices) { if (p < lo) lo = p; if (p > hi) hi = p; }
            if (hi - lo < 1e-6) { hi += 1; lo -= 1; }
            const pad = (hi - lo) * 0.12; lo -= pad; hi += pad;
            const X = i => i / (prices.length - 1) * (w - 6) + 3;
            const Y = p => h - 8 - (p - lo) / (hi - lo) * (h - 16);
            g.strokeStyle = '#cfd3df'; g.lineWidth = 1.4; g.beginPath();
            prices.forEach((p, i) => { i ? g.lineTo(X(i), Y(p)) : g.moveTo(X(i), Y(p)); });
            g.stroke();
            g.fillStyle = 'rgba(207,211,223,0.07)';
            g.lineTo(X(prices.length - 1), h); g.lineTo(X(0), h); g.closePath(); g.fill();
        }

        function drawDist() {
            const [g, w, h] = fit(disCv, 150);
            g.clearRect(0, 0, w, h);
            const n = rets.length; if (n < 20) return;
            let m = 0; for (const x of rets) m += x; m /= n;
            let v = 0; for (const x of rets) { const d = x - m; v += d * d; } v /= n;
            const sd = Math.sqrt(v); if (sd < 1e-9) return;
            const NB = 49, LOmin = -6, LOmax = 6, bw = (LOmax - LOmin) / NB;
            const cnt = new Float64Array(NB);
            for (const x of rets) { const z = (x - m) / sd; let b = Math.floor((z - LOmin) / bw); if (b >= 0 && b < NB) cnt[b]++; }
            // gaussian expected
            const gx = z => n * bw * Math.exp(-z * z / 2) / Math.sqrt(2 * Math.PI);
            let mx = 0; for (let i = 0; i < NB; i++) { const z = LOmin + (i + 0.5) * bw; mx = Math.max(mx, cnt[i], gx(z)); }
            const X = z => (z - LOmin) / (LOmax - LOmin) * (w - 6) + 3;
            const Y = val => h - 14 - val / mx * (h - 22);
            // zero axis + ±3sigma guides
            g.strokeStyle = '#1c2230'; g.lineWidth = 1;
            [-3, 3].forEach(z => { g.beginPath(); g.moveTo(X(z), 6); g.lineTo(X(z), h - 12); g.stroke(); });
            // bars
            for (let i = 0; i < NB; i++) {
                if (cnt[i] <= 0) continue;
                const z = LOmin + (i + 0.5) * bw;
                const x0 = X(LOmin + i * bw), x1 = X(LOmin + (i + 1) * bw);
                const tail = Math.abs(z) > 3;
                g.fillStyle = tail ? '#ff5e57' : 'rgba(90,134,214,0.55)';
                let yh = Math.max(Y(cnt[i]), tail ? h - 16 : Y(cnt[i]));
                const top = Y(cnt[i]); const barH = Math.max(h - 12 - top, tail ? 2.2 : 0.5);
                g.fillRect(x0 + 0.5, h - 12 - barH, (x1 - x0) - 1, barH);
            }
            // gaussian overlay
            g.strokeStyle = getComputedStyle(document.documentElement).getPropertyValue('--gauss') || '#5a6172';
            g.setLineDash([4, 3]); g.lineWidth = 1.5; g.beginPath();
            for (let z = LOmin; z <= LOmax; z += 0.1) { const X0 = X(z), Y0 = Y(gx(z)); z === LOmin ? g.moveTo(X0, Y0) : g.lineTo(X0, Y0); }
            g.stroke(); g.setLineDash([]);
        }

        // ---- UI refs ----
        const badge = document.getElementById('badge'), story = document.getElementById('story');
        const rG = document.getElementById('rGiant'), rK = document.getElementById('rKurt'), rM = document.getElementById('rMax');
        const lblC = document.getElementById('lblC'), lblA = document.getElementById('lblA');
        // spec 002: regime 表示のヒステリシス — 新 regime が REGIME_HOLD_MS 連続したときだけ表示を切替
        const REGIME_HOLD_MS = 1500;
        let lastCls = 'sub', candCls = 'sub', candSince = 0;
        function paintUI() {
            const s = stats(); const inst = regime(s.gf);
            const tNow = performance.now();
            if (inst.cls !== candCls) { candCls = inst.cls; candSince = tNow; }
            if (candCls !== lastCls && tNow - candSince >= REGIME_HOLD_MS) {
                lastCls = candCls;
                story.innerHTML = '<b>いま見えていること:</b> ' + stories[lastCls];
                const b = story.querySelector('b'); if (b) b.style.color = REGIMES[lastCls].col;
            }
            const reg = REGIMES[lastCls];
            badge.textContent = '— ' + reg.txt;
            badge.style.color = reg.col; badge.style.borderColor = reg.col;
            badge.style.background = reg.col + '1a';
            rG.textContent = Math.round(s.gf * 100) + '%'; rG.style.color = reg.col;
            rK.textContent = (s.kurt >= 0 ? '+' : '') + s.kurt.toFixed(1); rK.style.color = s.kurt > 3 ? '#ff5e57' : (s.kurt > 1 ? '#e0a64e' : '#e8e9ee');
            rM.textContent = (s.mx * 100).toFixed(1) + '%'; rM.style.color = s.mx > 0.07 ? '#ff5e57' : '#e8e9ee';
            lblC.style.color = reg.col;
        }

        let acc = 0, last = performance.now();
        function loop(now) {
            const dt = now - last; last = now;
            if (running) { acc += dt; while (acc >= 75) { step(); acc -= 75; } }
            flashA *= 0.86; flash.style.opacity = (flashA * 0.5).toFixed(3);
            drawNet(); drawPrice(); drawDist(); paintUI();
            requestAnimationFrame(loop);
        }

        // ---- controls ----
        const sC = document.getElementById('sC'), sA = document.getElementById('sA');
        sC.addEventListener('input', e => { c = +e.target.value; lblC.textContent = c.toFixed(2); });
        sA.addEventListener('input', e => { a = +e.target.value; lblA.textContent = a.toFixed(2); });
        document.getElementById('bPlay').addEventListener('click', e => { running = !running; e.target.textContent = running ? '⏸ pause' : '▶ play'; last = performance.now(); });
        document.getElementById('bReset').addEventListener('click', () => { price = 100; rets.length = 0; prices.length = 0; flashA = 0; });

        // warm up so panels aren't empty
        for (let i = 0; i < 120; i++) step();
        requestAnimationFrame(loop);
    })();
</script>
